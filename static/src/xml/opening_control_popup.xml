<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="cs_pos_cash_control.OpeningControlPopup"
       t-inherit="point_of_sale.OpeningControlPopup"
       t-inherit-mode="extension">
        <xpath expr="//Input" position="attributes">
            <attribute name="readonly">csFixedOpeningCashEnabled</attribute>
        </xpath>
        <xpath expr="//div[hasclass('cash-input-sub-section')]/div[hasclass('button')]" position="attributes">
            <attribute name="t-if">!csFixedOpeningCashEnabled</attribute>
        </xpath>
    </t>
</templates>
